/*
 * Shared keymap logic for 3*6 split keyboards (Corne, Cornix).
 *
 * Layers
 *   BASE: Standard QWERTY
 *   NAV:  Navigation (semicolon hold)
 *   NUM:  Numbers + Symbols (RCMD hold)
 *   FN:   Functions (NAV + NUM hold)
 *
 * Requires (include BEFORE this file):
 *   #include <behaviors.dtsi>
 *   #include <dt-bindings/zmk/bt.h>
 *   #include <dt-bindings/zmk/keys.h>
 *   #include <dt-bindings/zmk/outputs.h>
 *   #include <zmk-helpers/helper.h>
 *   #include "<keyboard>.h"
 *
 * Provides:
 *   - Layer indices, behavior shortcuts, NOSHIFT mod-morphs
 *   - Behaviors: nav / nav_semi / num / tri
 *   - Per-row binding macros (only the fully-shared blocks; the
 *     board-specific rows stay in each .keymap)
 */

#pragma once

// ─── Layer indices ───────────────────────────────────────────
#define BASE 0
#define NAV  1
#define NUM  2
#define FN   3

// ─── Behavior shortcuts ──────────────────────────────────────
#define ___      &trans
#define NUM_RCMD &num NUM RCMD
#define HY(x)    &kp LC(LA(LG(LS(x))))
#define CW       &caps_word
#define BOOT     &bootloader
#define RESET    &sys_reset
#define PREV     &kp C_PREV
#define NEXT     &kp C_NEXT
#define VOL_DN   &kp C_VOL_DN
#define VOL_UP   &kp C_VOL_UP
#define MUTE     &kp C_MUTE
#define SLEEP    &soft_off
#define BT(x)    &bt BT_SEL x
#define BTC      &bt BT_CLR
#define BTCA     &bt BT_CLR_ALL
#define OUTT     &out OUT_TOG

// No-Shift mod-morph: ignores Shift so the base keycode is always sent
#define NOSHIFT(name, keycode) \
        ZMK_MOD_MORPH(name, \
                      bindings = <&kp keycode>, <&kp keycode>; \
                      mods = <(MOD_LSFT)>;)

NOSHIFT(ns_n1,    N1)
NOSHIFT(ns_n2,    N2)
NOSHIFT(ns_n3,    N3)
NOSHIFT(ns_n4,    N4)
NOSHIFT(ns_n5,    N5)
NOSHIFT(ns_n6,    N6)
NOSHIFT(ns_n7,    N7)
NOSHIFT(ns_n8,    N8)
NOSHIFT(ns_n9,    N9)
NOSHIFT(ns_n0,    N0)
NOSHIFT(ns_minus, MINUS)
NOSHIFT(ns_equal, EQUAL)
NOSHIFT(ns_grave, GRAVE)
NOSHIFT(ns_bslh,  BSLH)

// ─── Behaviors ───────────────────────────────────────────────
// NAV: hold=layer, tap=; (positional hold-trigger avoids misfires)
ZMK_HOLD_TAP(nav, bindings = <&mo>, <&kp>; flavor = "hold-preferred";
             tapping-term-ms = <300>; quick-tap-ms = <0>;
             //  LT5 LT4 LT3 LT2 LT1 LT0 RT0 RT1 RT2 RT3 RT4 RT5
             //  LM5 LM4 LM3 LM2 LM1 LM0 RM0 RM1 RM2 RM3 RM4 RM5
             //  LB5 LB4 LB3 LB2 LB1 LB0 RB0 RB1 RB2 RB3 RB4 RB5
             //              LH2 LH1 LH0 RH0 RH1 RH2
             hold-trigger-key-positions = <
                                         RT0 RT1 RT2 RT3 RT4 RT5
                 LM5                     RM0 RM1 RM2 RM3 RM4 RM5
                 LB5                     RB0 RB1 RB2 RB3 RB4 RB5
                             LH2 LH1     RH1                    >;)

ZMK_MOD_MORPH(nav_semi, bindings = <&nav NAV SEMI>, <&nav NAV COLON>;
              mods = <(MOD_LSFT)>; keep-mods = <MOD_LSFT>;)

ZMK_HOLD_TAP(num, bindings = <&mo>, <&kp>; flavor = "balanced";
             tapping-term-ms = <150>; quick-tap-ms = <0>;)

ZMK_CONDITIONAL_LAYER(tri, NAV NUM, FN)

// ─── Shared row blocks ───────────────────────────────────────
//              ╭─────────┬─────────┬─────────┬─────────┬─────────┬─────────╮
#define BASE_L1  &kp TAB   &kp Q     &kp W     &kp E     &kp R     &kp T
//              ├─────────┼─────────┼─────────┼─────────┼─────────┼─────────┤
#define BASE_L2  &kp LCTRL &kp A     &kp S     &kp D     &kp F     &kp G
//              ├─────────┼─────────┼─────────┼─────────┼─────────┼─────────┤
#define BASE_L3  &kp LSHFT &kp Z     &kp X     &kp C     &kp V     &kp B
//              ╰─────────────────────────────┼─────────┼─────────┼─────────┤
#define BASE_LT                                &kp LALT  &kp LGUI  &kp SPACE
//                                            ╰─────────┴─────────┴─────────╯

//              ╭─────────┬─────────┬─────────┬─────────┬─────────┬─────────╮
#define BASE_R1  &kp Y     &kp U     &kp I     &kp O     &kp P     &kp LBKT
//              ├─────────┼─────────┼─────────┼─────────┼─────────┼─────────┤
#define BASE_R2  &kp H     &kp J     &kp K     &kp L     &nav_semi &kp SQT
//              ├─────────┼─────────┼─────────┼─────────┼─────────┼─────────┤
#define BASE_R3  &kp N     &kp M     &kp COMMA &kp DOT   &kp FSLH  &kp RBKT
//              ├─────────┼─────────┼─────────┼─────────────────────────────╯
#define BASE_RT  &kp RET   NUM_RCMD  &kp BSPC
//              ╰─────────┴─────────┴─────────╯

//             ╭─────────┬─────────┬─────────┬─────────┬─────────┬─────────╮
#define NAV_L1  ___       ___       ___       ___       ___       ___
//             ├─────────┼─────────┼─────────┼─────────┼─────────┼─────────┤
#define NAV_L2  ___       ___       ___       ___       ___       ___
//             ├─────────┼─────────┼─────────┼─────────┼─────────┼─────────┤
#define NAV_L3  ___       ___       ___       ___       ___       ___
//             ╰─────────────────────────────┼─────────┼─────────┼─────────┤
#define NAV_LT                                ___       ___       ___
//                                           ╰─────────┴─────────┴─────────╯

//             ╭─────────┬─────────┬─────────┬─────────┬─────────┬─────────╮
#define NAV_R1  &kp DEL   HY(N1)    HY(N2)    &tog NAV  ___       ___
//             ├─────────┼─────────┼─────────┼─────────┼─────────┼─────────┤
#define NAV_R2  &kp LEFT  &kp DOWN  &kp UP    &kp RIGHT &kp SEMI  &kp SEMI
//             ├─────────┼─────────┼─────────┼─────────┼─────────┼─────────┤
#define NAV_R3  &kp HOME  &kp PG_DN &kp PG_UP &kp END   &kp INS   ___
//             ├─────────┼─────────┼─────────┼─────────────────────────────╯
#define NAV_RT  ___       ___       ___
//             ╰─────────┴─────────┴─────────╯

//             ╭─────────┬─────────┬─────────┬─────────┬─────────┬─────────╮
#define NUM_L1  &kp ESC   &kp EXCL  &kp AT    &kp HASH  &kp DLLR  &kp PRCNT
//             ├─────────┼─────────┼─────────┼─────────┼─────────┼─────────┤
#define NUM_L2  ___       &ns_n1    &ns_n2    &ns_n3    &ns_n4    &ns_n5
//             ├─────────┼─────────┼─────────┼─────────┼─────────┼─────────┤
#define NUM_L3  ___       CW        &kp UNDER &ns_minus &ns_equal &kp PLUS
//             ╰─────────────────────────────┼─────────┼─────────┼─────────┤
#define NUM_LT                                ___       ___       ___
//                                           ╰─────────┴─────────┴─────────╯

//             ╭─────────┬─────────┬─────────┬─────────┬─────────┬─────────╮
#define NUM_R1  &kp CARET &kp AMPS  &kp STAR  &kp LPAR  &kp RPAR  &kp TILDE
//             ├─────────┼─────────┼─────────┼─────────┼─────────┼─────────┤
#define NUM_R2  &ns_n6    &ns_n7    &ns_n8    &ns_n9    &ns_n0    &ns_grave
//             ├─────────┼─────────┼─────────┼─────────┼─────────┼─────────┤
#define NUM_R3  &ns_bslh  &kp PIPE  ___       ___       ___       &kp SPACE
//             ├─────────┼─────────┼─────────┼─────────────────────────────╯
#define NUM_RT  ___       ___       ___
//             ╰─────────┴─────────┴─────────╯

//            ╭─────────┬─────────┬─────────┬─────────┬─────────┬─────────╮
#define FN_L1  &kp F1    &kp F2    &kp F3    &kp F4    &kp F5    &kp F6
//            ├─────────┼─────────┼─────────┼─────────┼─────────┼─────────┤
#define FN_L2  ___       ___       ___       PREV      NEXT      VOL_UP
//            ╰─────────────────────────────┼─────────┼─────────┼─────────┤
#define FN_LT                                ___       ___       &kp C_PP
//                                          ╰─────────┴─────────┴─────────╯

//            ╭─────────┬─────────┬─────────┬─────────┬─────────┬─────────╮
#define FN_R1  &kp F7    &kp F8    &kp F9    &kp F10   &kp F11   &kp F12
//            ├─────────┼─────────┼─────────┼─────────┼─────────┼─────────┤
#define FN_R2  BT(0)     BT(1)     BT(2)     BT(3)     ___       BT(4)
//            ├─────────┼─────────┼─────────┼─────────────────────────────╯
#define FN_RT  ___       ___       ___
//            ╰─────────┴─────────┴─────────╯
